{
  "name": "SecondaryObject",
  "type": "object",
  "properties": {
    "marketType": {
      "type": "string",
      "enum": ["secondary"],
      "default": "secondary",
      "description": "Market type identifier"
    },
    "title": {
      "type": "string",
      "description": "Objekto pavadinimas"
    },
    "address": {
      "type": "string",
      "description": "Pilnas adresas"
    },
    "city": {
      "type": "string",
      "description": "Miestas"
    },
    "district": {
      "type": "string",
      "description": "Rajonas"
    },
    "propertyType": {
      "type": "string",
      "enum": ["apartment", "house", "townhouse", "land", "office", "other"],
      "description": "Nuosavybės tipas"
    },
    "rooms": {
      "type": "number",
      "description": "Kambarių skaičius"
    },
    "area": {
      "type": "number",
      "description": "Plotas m²"
    },
    "floor": {
      "type": "number",
      "description": "Aukštas"
    },
    "price": {
      "type": "number",
      "description": "Kaina €"
    },
    "objectStatus": {
      "type": "string",
      "enum": ["available", "reserved", "sold", "paused"],
      "default": "available",
      "description": "Objekto statusas"
    },
    "assignedAgentUserId": {
      "type": "string",
      "description": "Priskirtam agentui"
    },
    "sellerClientId": {
      "type": "string",
      "description": "Pardavėjo kliento ID"
    },
    "sourceType": {
      "type": "string",
      "enum": ["owner", "partner", "manual", "internal"],
      "default": "manual",
      "description": "Šaltinis"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "Ar aktyvus"
    },
    "isExclusive": {
      "type": "boolean",
      "default": false,
      "description": "Ar ekskluzyvi agentuotė"
    },
    "publicDescription": {
      "type": "string",
      "description": "Vie šai rodomas aprašas"
    },
    "internalNotes": {
      "type": "string",
      "description": "Vidinės pastabos"
    },
    "mainImageUrl": {
      "type": "string",
      "description": "Pagrindinė nuotrauka"
    },
    "imageUrls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Nuotraukų sąrašas"
    },
    "floorPlanUrls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Planų nuotraukos"
    },
    "galleryOrder": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Galerijos eilutė"
    },
    "serviceType": {
      "type": "string",
      "enum": ["sale", "rent"],
      "default": "sale",
      "description": "Paslaugos tipas"
    },
    "commissionType": {
      "type": "string",
      "enum": ["percentage", "fixed"],
      "default": "percentage",
      "description": "Komisinio tipas"
    },
    "commissionPercent": {
      "type": "number",
      "description": "Komisinio procentas"
    },
    "commissionFixedAmount": {
      "type": "number",
      "description": "Fiksuota komisinio suma"
    },
    "vatMode": {
      "type": "string",
      "enum": ["with_vat", "without_vat"],
      "default": "without_vat",
      "description": "PVM režimas"
    },
    "createdByUserId": {
      "type": "string",
      "description": "Sukūręs vartotojas"
    }
  },
  "required": [
    "title",
    "address",
    "city",
    "propertyType",
    "rooms",
    "area",
    "price",
    "assignedAgentUserId",
    "sellerClientId",
    "createdByUserId"
  ]
}