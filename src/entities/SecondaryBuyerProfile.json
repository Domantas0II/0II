{
  "name": "SecondaryBuyerProfile",
  "type": "object",
  "properties": {
    "marketType": {
      "type": "string",
      "enum": ["secondary"],
      "default": "secondary",
      "description": "Market type identifier"
    },
    "clientId": {
      "type": "string",
      "description": "Kliento ID"
    },
    "assignedAgentUserId": {
      "type": "string",
      "description": "Priskirtam agentui"
    },
    "profileStatus": {
      "type": "string",
      "enum": ["active", "paused", "completed", "archived"],
      "default": "active",
      "description": "Profilio statusas"
    },
    "serviceType": {
      "type": "string",
      "enum": ["search", "rent"],
      "default": "search",
      "description": "Paslaugos tipas"
    },
    "city": {
      "type": "string",
      "description": "Pageidaujamas miestas"
    },
    "district": {
      "type": "string",
      "description": "Pageidaujamas rajonas"
    },
    "propertyType": {
      "type": "string",
      "enum": ["apartment", "house", "townhouse", "land", "office", "other"],
      "description": "Pageidaujama nuosavybės tipas"
    },
    "rooms": {
      "type": "number",
      "description": "Norimas kambarių skaičius"
    },
    "areaMin": {
      "type": "number",
      "description": "Minimalus plotas m²"
    },
    "areaMax": {
      "type": "number",
      "description": "Maksimalus plotas m²"
    },
    "budgetMin": {
      "type": "number",
      "description": "Minimalus biudžetas €"
    },
    "budgetMax": {
      "type": "number",
      "description": "Maksimalus biudžetas €"
    },
    "floorPreference": {
      "type": "string",
      "description": "Aukšto pageidavimas"
    },
    "conditionPreference": {
      "type": "string",
      "enum": ["fully_finished", "partial_finish", "not_finished"],
      "description": "Stūkos būsena"
    },
    "parkingNeed": {
      "type": "boolean",
      "default": false,
      "description": "Reikalingas parkavimas"
    },
    "deadline": {
      "type": "string",
      "format": "date",
      "description": "Pirkinimo terminas"
    },
    "financingStatus": {
      "type": "string",
      "enum": ["ready", "pre_approved", "needs_approval", "no_financing"],
      "default": "ready",
      "description": "Finansavimo statusas"
    },
    "commissionType": {
      "type": "string",
      "enum": ["percentage", "fixed", "hybrid"],
      "default": "percentage",
      "description": "Komisinio tipas"
    },
    "searchCommissionPercent": {
      "type": "number",
      "description": "Paieškos komisinio procentas"
    },
    "negotiationBonusPercent": {
      "type": "number",
      "description": "Derybų bonus procentas"
    },
    "commissionFixedAmount": {
      "type": "number",
      "description": "Fiksuota komisinio suma"
    },
    "vatMode": {
      "type": "string",
      "enum": ["with_vat", "without_vat"],
      "default": "without_vat",
      "description": "PVM režimas"
    },
    "internalNotes": {
      "type": "string",
      "description": "Vidinės pastabos"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "Ar aktyvus profilis"
    },
    "createdByUserId": {
      "type": "string",
      "description": "Sukūręs vartotojas"
    }
  },
  "required": [
    "clientId",
    "assignedAgentUserId",
    "city",
    "propertyType",
    "budgetMin",
    "budgetMax",
    "createdByUserId"
  ]
}